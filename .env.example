# ── OpenFrame AI — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your API keys.
#
#   cp .env.example .env
#
# You can also set keys at runtime via Settings > API Keys in the UI.
# ──────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────

# OpenRouter — LLM gateway for all AI agent calls
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Default paid model (used when no per-agent model is selected)
# See full list: https://openrouter.ai/models
OPENROUTER_PAID_MODEL=anthropic/claude-sonnet-4-20250514

# kie.ai — Image & video generation (Seedream, Kling, Wan, Veo, etc.)
# Get your key: https://kie.ai/
KIE_API_KEY=

# ── RECOMMENDED ──────────────────────────────────────────────────

# ImgBB — Free image hosting (needed for reference images in generation)
# Get your key: https://api.imgbb.com/
IMGBB_API_KEY=

# Free model fallback (used for testing / low-cost runs)
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ── LICENSING (optional) ─────────────────────────────────────
# License key — leave empty for community mode (all features available)
# Request a key: https://openframe.ai/license
# OPENFRAME_LICENSE_KEY=
